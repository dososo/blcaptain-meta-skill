{
  "skill": "blcaptain-meta-skill",
  "purpose": "Validate routing fixture coverage for the meta skill. This is not a substitute for fresh-context model forward-test.",
  "minimum_counts": {
    "positive": 4,
    "negative": 4,
    "near_neighbor": 3,
    "boundary": 2
  },
  "description_must_include": [
    "Use when",
    "turn",
    "repeated workflow",
    "Agent Skill",
    "SKILL.md",
    "evals",
    "gotchas",
    "Non-Skill"
  ],
  "cases": [
    {
      "id": "pos-001",
      "type": "positive",
      "query": "请把这套重复的客服 SOP 产品化成一个 Claude Skill，包含 SKILL.md、references、eval 和 gotchas。",
      "expected_route": "trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "required_signals": ["Skill", "SKILL.md", "eval", "gotchas"]
    },
    {
      "id": "pos-002",
      "type": "positive",
      "query": "We have a repeated workflow. Package it as a reusable Agent Skill with scripts, assets, route tests, and governance metadata.",
      "expected_route": "trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "required_signals": ["Agent Skill", "scripts", "assets", "route tests", "governance"]
    },
    {
      "id": "pos-003",
      "type": "positive",
      "query": "帮我审计这个现有 SKILL.md，看看 description 是否误触发、references 是否过重、eval 是否够。",
      "expected_route": "trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": true,
      "required_signals": ["SKILL.md", "description", "references", "eval"]
    },
    {
      "id": "pos-004",
      "type": "positive",
      "query": "根据这份 PRD，把方法论落成可发布、可测试、可运营的通用 Agent Skill。",
      "expected_route": "trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "required_signals": ["Agent Skill", "PRD", "可测试", "可运营"]
    },
    {
      "id": "neg-001",
      "type": "negative",
      "query": "帮我总结这篇文章的三个观点。",
      "expected_route": "no_trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "forbidden_signals": ["Skill", "SKILL.md", "eval"]
    },
    {
      "id": "neg-002",
      "type": "negative",
      "query": "解释一下 Python 的 pathlib 怎么用。",
      "expected_route": "no_trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "forbidden_signals": ["Skill", "Agent Skill"]
    },
    {
      "id": "neg-003",
      "type": "negative",
      "query": "把这段客服话术润色得更自然一点。",
      "expected_route": "no_trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "forbidden_signals": ["Skill", "SKILL.md"]
    },
    {
      "id": "neg-004",
      "type": "negative",
      "query": "给我一个今天下午的学习计划。",
      "expected_route": "no_trigger",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "forbidden_signals": ["Skill", "Agent Skill"]
    },
    {
      "id": "near-001",
      "type": "near_neighbor",
      "query": "帮我写一个项目 AGENTS.md，记录测试命令和代码风格。",
      "expected_route": "other_artifact",
      "fresh_context_required": true,
      "multi_skill_environment_required": true,
      "required_signals": ["AGENTS.md", "测试命令", "代码风格"],
      "target_artifact_signals": ["AGENTS.md"],
      "forbidden_signals": ["Skill", "SKILL.md", "eval", "Agent Skill", "Claude Skill", "Codex Skill"]
    },
    {
      "id": "near-002",
      "type": "near_neighbor",
      "query": "把这个确定性 CSV 清洗流程写成一个 CLI 脚本。",
      "expected_route": "other_artifact",
      "fresh_context_required": true,
      "multi_skill_environment_required": true,
      "required_signals": ["CLI", "脚本"],
      "target_artifact_signals": ["CLI", "脚本"],
      "forbidden_signals": ["Skill", "SKILL.md", "eval", "Agent Skill", "Claude Skill", "Codex Skill"]
    },
    {
      "id": "near-003",
      "type": "near_neighbor",
      "query": "帮我做一个普通 README，给人类用户看安装步骤。",
      "expected_route": "other_artifact",
      "fresh_context_required": true,
      "multi_skill_environment_required": true,
      "required_signals": ["README", "安装步骤"],
      "target_artifact_signals": ["README", "安装步骤"],
      "forbidden_signals": ["Skill", "SKILL.md", "eval", "Agent Skill", "Claude Skill", "Codex Skill"]
    },
    {
      "id": "boundary-001",
      "type": "boundary",
      "query": "我以后可能想把自己的写作方法做成 Skill，你先帮我判断值不值得。",
      "expected_route": "trigger_for_decision_only",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "required_signals": ["Skill", "判断", "值不值得"]
    },
    {
      "id": "boundary-002",
      "type": "boundary",
      "query": "我有一份 SOP，可能只是文档，也可能要给 Agent 执行，帮我分辨。",
      "expected_route": "trigger_for_decision_only",
      "fresh_context_required": true,
      "multi_skill_environment_required": false,
      "required_signals": ["SOP", "Agent", "分辨"]
    }
  ]
}
